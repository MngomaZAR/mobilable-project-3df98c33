# Copy this file to .env and fill in real values
# Do NOT commit .env with real keys

# Legacy Supabase fallback (ignored when EXPO_PUBLIC_BACKEND_PROVIDER=nhost)
# Do not use this for release while Supabase free-plan limits are blocking production.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: app also accepts EXPO_PUBLIC_SUPABASE_KEY as fallback for the anon key
# EXPO_PUBLIC_SUPABASE_KEY=your-anon-key-here

# Commerce / store compliance (required for release CI)
# development | web | internal | appstore | play | both
EXPO_PUBLIC_STORE_TARGET=development
# iap | external | disabled
EXPO_PUBLIC_DIGITAL_BILLING_PROVIDER=external
# true/false - must be true for store builds when billing provider is not iap
EXPO_PUBLIC_DISABLE_DIGITAL_PURCHASES=false

# Public backend API (FastAPI/Dokploy target)
EXPO_PUBLIC_API_BASE_URL=https://api.example.com

# Routing/navigation
# osrm = self-hosted or public OSRM-compatible endpoint
# ors = OpenRouteService hosted directions API
EXPO_PUBLIC_ROUTING_PROVIDER=osrm
EXPO_PUBLIC_OSRM_BASE_URL=https://router.project-osrm.org
# EXPO_PUBLIC_OPENROUTESERVICE_API_KEY=

# Optional: Hasura GraphQL endpoint
# EXPO_PUBLIC_HASURA_URL=https://your-project-hasura.example.com/v1/graphql
# EXPO_PUBLIC_HASURA_ANON_KEY=your-hasura-anon-key

# Backend provider
# supabase | nhost
EXPO_PUBLIC_BACKEND_PROVIDER=nhost

# Nhost (optional, for the backend migration path)
EXPO_PUBLIC_NHOST_SUBDOMAIN=otismbqjmpvvtygfjbcu
EXPO_PUBLIC_NHOST_REGION=ap-southeast-1

# Optional: Google Maps (for react-native-maps on Android)
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional: add other public env vars here
# EXPO_PUBLIC_MAPBOX_TOKEN=pk.xxx
