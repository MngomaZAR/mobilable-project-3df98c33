# Copy this file to .env and fill in real values
# Do NOT commit .env with real keys

# Supabase (required for auth, feed, chat, photographers)
# Get these from your Supabase project: Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: app also accepts EXPO_PUBLIC_SUPABASE_KEY as fallback for the anon key
# EXPO_PUBLIC_SUPABASE_KEY=your-anon-key-here

# Optional: Hasura GraphQL endpoint (if you prefer Hasura over Supabase)
# EXPO_PUBLIC_HASURA_URL=https://your-project-hasura.herokuapp.com/v1/graphql
# EXPO_PUBLIC_HASURA_ANON_KEY=your-hasura-anon-key

# Optional: add other public env vars here
# EXPO_PUBLIC_MAPBOX_TOKEN=pk.xxx
