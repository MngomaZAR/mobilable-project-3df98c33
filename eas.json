{
  "cli": {
    "version": ">= 16.16.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true",
        "EXPO_PUBLIC_STORE_TARGET": "internal",
        "EXPO_PUBLIC_DIGITAL_BILLING_PROVIDER": "external",
        "EXPO_PUBLIC_DISABLE_DIGITAL_PURCHASES": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EAS_NO_VCS": "1",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true",
        "EXPO_PUBLIC_STORE_TARGET": "both",
        "EXPO_PUBLIC_DIGITAL_BILLING_PROVIDER": "external",
        "EXPO_PUBLIC_DISABLE_DIGITAL_PURCHASES": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6760158086"
      },
      "android": {
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
