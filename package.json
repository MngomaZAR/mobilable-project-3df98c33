{
  "name": "papzi",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "report": "node scripts/analyzeRepo.js",
    "supabase:login": "npx supabase login",
    "supabase:link": "npx supabase link --project-ref mizdvqhvspkjayffaqqd",
    "supabase:push": "npx supabase db push",
    "db:migrate": "npx supabase db push",
    "test": "jest",
    "test:e2e": "jest --config jest.e2e.config.cjs",
    "test:hasura": "EXPO_PUBLIC_HASURA_URL=http://localhost:8080/v1/graphql jest __tests__/hasura.e2e.test.ts --runInBand --detectOpenHandles",
    "hasura:up": "docker-compose -f docker/hasura/docker-compose.yml up -d",
    "hasura:down": "docker-compose -f docker/hasura/docker-compose.yml down",
    "hasura:logs": "docker-compose -f docker/hasura/docker-compose.yml logs -f",
    "eas:build": "npx eas-cli@latest build --platform all",
    "eas:build:workflow": "npx eas-cli@latest workflow:run .eas/workflows/create-production-builds.yml",
    "eas:build:ios": "npx eas-cli@latest workflow:run .eas/workflows/build-ios-preview.yml",
    "eas:deploy:web": "npx eas-cli@latest workflow:run .eas/workflows/deploy-web.yml",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.3.3",
    "@react-navigation/material-top-tabs": "^7.3.3",
    "@react-navigation/native": "^7.1.10",
    "@react-navigation/stack": "^7.7.1",
    "@supabase/supabase-js": "latest",
    "expo": "~54.0.0",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "latest",
    "expo-image-picker": "latest",
    "expo-linear-gradient": "latest",
    "expo-location": "latest",
    "expo-notifications": "latest",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "^55.0.9",
    "moment": "2.30.1",
    "react": "19.2.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-chart-kit": "6.12.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-pager-view": "6.9.1",
    "react-native-paper": "5.14.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-reanimated-carousel": "^3.5.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-tab-view": "^4.0.12",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/eslint-parser": "latest",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.3",
    "@types/react": "~19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/parser": "latest",
    "babel-preset-expo": "^54.0.10",
    "eslint": "latest",
    "eslint-plugin-react": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-native": "latest",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "lint-staged": "^16.3.2",
    "react-test-renderer": "^19.1.0",
    "supabase": "^2.75.0",
    "ts-jest": "^29.1.0",
    "typescript": "latest"
  },
  "private": true
}
