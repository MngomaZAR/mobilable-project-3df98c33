{
  "name": "my-simple-expo",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "report": "node scripts/analyzeRepo.js",
    "supabase:login": "npx supabase login",
    "supabase:link": "npx supabase link --project-ref luxppjfrlsnvtslundfz",
    "supabase:push": "npx supabase db push",
    "db:migrate": "npx supabase db push",
    "test": "jest --passWithNoTests",
    "test:hasura": "EXPO_PUBLIC_HASURA_URL=http://localhost:8080/v1/graphql jest __tests__/hasura.e2e.test.ts --runInBand --detectOpenHandles",
    "hasura:up": "docker-compose -f docker/hasura/docker-compose.yml up -d",
    "hasura:down": "docker-compose -f docker/hasura/docker-compose.yml down",
    "hasura:logs": "docker-compose -f docker/hasura/docker-compose.yml logs -f"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "@react-native-async-storage/async-storage": "1.24.0",
    "@react-navigation/bottom-tabs": "^7.3.3",
    "@react-navigation/material-top-tabs": "^7.3.3",
    "@react-navigation/native": "^7.1.10",
    "@react-navigation/stack": "^7.7.1",
    "@supabase/supabase-js": "latest",
    "expo": "~54.0.0",
    "expo-image-manipulator": "latest",
    "expo-image-picker": "latest",
    "expo-linear-gradient": "latest",
    "expo-location": "latest",
    "expo-notifications": "latest",
    "expo-status-bar": "~1.12.1",
    "moment": "2.30.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.76.1",
    "react-native-chart-kit": "6.12.0",
    "react-native-gesture-handler": "~2.18.1",
    "react-native-maps": "latest",
    "react-native-pager-view": "6.4.1",
    "react-native-paper": "5.14.5",
    "react-native-reanimated": "~3.15.4",
    "react-native-reanimated-carousel": "^3.5.1",
    "react-native-safe-area-context": "4.11.0",
    "react-native-screens": "^4.22.0",
    "react-native-svg": "^15.8.0",
    "react-native-tab-view": "^4.0.12",
    "react-native-web": "^0.21.0",
    "react-native-webview": "latest"
