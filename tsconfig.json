{
  "extends": "./node_modules/expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "allowJs": false,
    "noEmit": true,
    "resolveJsonModule": true,
    "noImplicitAny": true,
    "types": ["react", "react-native", "jest", "node"]
